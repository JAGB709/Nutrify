nutri:salmon   a nutri:Pescado ;
    nutri:calorias_100g "208.0"^^xsd:float ; nutri:proteinas_100g "20.4"^^xsd:float ;
    nutri:grasas_100g "12.4"^^xsd:float    ; nutri:carbohidratos_100g "0.0"^^xsd:float .

