@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix nutri: <http://nutrify.si.upm.es/ontologia#> .

# ── Jerarquía de clases RDFS ─────────────────────────────────────────────────
# Jena aplica rdfs9: si X rdf:type A y A rdfs:subClassOf B → X rdf:type B (inferido)
# Jena aplica rdfs11: transitivity de subClassOf → salmon rdf:type Alimento

nutri:Alimento  a rdfs:Class ; rdfs:label "Alimento" .
nutri:Proteina  a rdfs:Class ; rdfs:subClassOf nutri:Alimento ; rdfs:label "Proteina" .
nutri:Pescado   a rdfs:Class ; rdfs:subClassOf nutri:Proteina ; rdfs:label "Pescado" .
nutri:Carne     a rdfs:Class ; rdfs:subClassOf nutri:Proteina ; rdfs:label "Carne" .
nutri:Huevo     a rdfs:Class ; rdfs:subClassOf nutri:Proteina ; rdfs:label "Huevo" .
nutri:Legumbre  a rdfs:Class ; rdfs:subClassOf nutri:Proteina ; rdfs:label "Legumbre" .
nutri:Vegetal   a rdfs:Class ; rdfs:subClassOf nutri:Alimento ; rdfs:label "Vegetal" .
nutri:Fruta     a rdfs:Class ; rdfs:subClassOf nutri:Alimento ; rdfs:label "Fruta" .
nutri:Lacteo    a rdfs:Class ; rdfs:subClassOf nutri:Alimento ; rdfs:label "Lacteo" .
nutri:Cereal    a rdfs:Class ; rdfs:subClassOf nutri:Alimento ; rdfs:label "Cereal" .
nutri:Grasa     a rdfs:Class ; rdfs:subClassOf nutri:Alimento ; rdfs:label "Grasa" .

# ── Propiedades nutricionales (valores por 100 g) ────────────────────────────

nutri:calorias_100g      a rdf:Property ; rdfs:domain nutri:Alimento ; rdfs:range xsd:float .
nutri:proteinas_100g     a rdf:Property ; rdfs:domain nutri:Alimento ; rdfs:range xsd:float .
nutri:grasas_100g        a rdf:Property ; rdfs:domain nutri:Alimento ; rdfs:range xsd:float .
nutri:carbohidratos_100g a rdf:Property ; rdfs:domain nutri:Alimento ; rdfs:range xsd:float .

